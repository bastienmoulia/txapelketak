rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Firestore rules allow operations but validation done in app + future Cloud Functions

    function isValidTournamentStatus(value) {
      return value == 'waitingValidation'
        || value == 'ongoing'
        || value == 'archived';
    }

    function isValidRole(value) {
      return value == 'admin' || value == 'organizer';
    }

    match /tournaments/{tournamentId} {
      allow get, list: if true;

      allow create: if request.resource.data.name is string
        && request.resource.data.description is string
        && isValidTournamentStatus(request.resource.data.status)
        && request.resource.data.createdAt is string;

      allow update: if request.resource.data.name is string
        && request.resource.data.description is string
        && isValidTournamentStatus(request.resource.data.status)
        && request.resource.data.createdAt is string;

      allow delete: if true;

      match /teams/{teamId} {
        allow get, list: if true;
        allow create, update, delete: if request.resource.data.name is string;
      }

      match /series/{serieId} {
        allow get, list: if true;
        allow create, update, delete: if request.resource.data.name is string;

        match /poules/{pouleId} {
          allow get, list: if true;
          allow create, update, delete: if request.resource.data.name is string
            && request.resource.data.refTeams is list;

          match /games/{gameId} {
            allow get, list: if true;
            allow create, delete: if true;
            allow update: if request.resource.data.scoreTeam1 is int
              || request.resource.data.scoreTeam2 is int
              || request.resource.data.date is string;
          }
        }

        match /playoffs/{playoffId} {
          allow get, list: if true;
          allow create, update, delete: if request.resource.data.name is string
            && request.resource.data.refTeams is list;

          match /games/{gameId} {
            allow get, list: if true;
            allow create, delete: if true;
            allow update: if request.resource.data.scoreTeam1 is int
              || request.resource.data.scoreTeam2 is int
              || request.resource.data.date is string;
          }
        }
      }

      match /timeSlots/{timeSlotId} {
        allow get, list: if true;
        allow create, update, delete: if request.resource.data.name is string;
      }
    }

    match /users/{userId} {
      allow get, list: if true;

      allow create: if request.resource.data.refTournament is path
        && request.resource.data.username is string
        && request.resource.data.email is string
        && request.resource.data.token is string
        && request.resource.data.token.size() >= 20
        && isValidRole(request.resource.data.role);

      allow update, delete: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
