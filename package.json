{
  "name": "txapelketak",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"npm run serve\" \"npm run emulators\"",
    "serve": "ng serve -o",
    "serve:test": "ng serve -o --configuration test",
    "serve:prod": "ng serve -o --configuration production",
    "build": "ng build",
    "build:test": "ng build --configuration test",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --coverage",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "e2e:ui": "ng e2e --ui",
    "emulators": "npx firebase emulators:start --only firestore,functions --import=.firebase/emulator-data --export-on-exit",
    "emulators:stop": "pkill -f \"firebase emulators:start\" || true; pkill -f \"cloud-firestore-emulator.*txapelketak-ac529\" || true; pkill -f \"/emulators/ui-v.*server.mjs\" || true",
    "emulators:reset": "npm run emulators:stop && npm run emulators",
    "functions:build": "cd functions && npm run build",
    "functions:deploy": "npm run functions:build && npx firebase deploy --only functions",
    "ncu": "npx npm-check-updates -i"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "@angular/cdk": "^21.2.13",
    "@angular/common": "^21.2.15",
    "@angular/compiler": "^21.2.15",
    "@angular/core": "^21.2.15",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.2.15",
    "@angular/platform-browser": "^21.2.15",
    "@angular/router": "^21.2.15",
    "@jsverse/transloco": "^8.3.0",
    "@ngrx/signals": "^21.1.0",
    "@primeuix/themes": "^2.0.3",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.4",
    "ngxtension": "^7.2.0",
    "primeng": "^21.1.8",
    "rxjs": "~7.8.2",
    "tailwindcss": "^4.3.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.5.2",
    "@analogjs/vitest-angular": "^2.5.2",
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.15",
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-istanbul": "^4.1.7",
    "angular-eslint": "21.4.0",
    "concurrently": "^10.0.0",
    "eslint": "^10.4.1",
    "firebase-tools": "^15.19.0",
    "ngxtension-plugin": "^7.2.0",
    "playwright": "^1.60.0",
    "playwright-ng-schematics": "^21.1.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "primeicons": "^7.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
