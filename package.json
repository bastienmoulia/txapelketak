{
  "name": "txapelketak",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"npm run serve\" \"npm run emulators\"",
    "serve": "ng serve -o",
    "serve:prod": "ng serve -o --configuration production",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "emulators": "npx firebase emulators:start --only firestore --import=.firebase/emulator-data --export-on-exit",
    "emulators:stop": "pkill -f \"firebase emulators:start\" || true; pkill -f \"cloud-firestore-emulator.*txapelketak-ac529\" || true; pkill -f \"/emulators/ui-v.*server.mjs\" || true",
    "emulators:reset": "npm run emulators:stop && npm run emulators",
    "ncu": "npx npm-check-updates -i"
  },
  "private": true,
  "packageManager": "npm@11.6.1",
  "dependencies": {
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@angular/service-worker": "^21.2.7",
    "@jsverse/transloco": "^8.3.0",
    "@ngrx/signals": "^21.1.0",
    "@primeuix/themes": "^2.0.3",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.0",
    "ngxtension": "^7.2.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.5",
    "rxjs": "~7.8.2",
    "tailwindcss": "^4.2.2",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.0",
    "@analogjs/vitest-angular": "^2.4.0",
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@vitest/browser-playwright": "^4.1.2",
    "angular-eslint": "21.3.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "ngxtension-plugin": "^7.2.0",
    "playwright": "^1.59.1",
    "playwright-ng-schematics": "^21.0.9",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.58.0",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^4.2.0",
    "vitest": "^4.1.2"
  }
}
